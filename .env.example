# ═══════════════════════════════════════════════════════════════════
#  MotionLens — environment variables template
#  Copy this file to `.env` (gitignored) and fill in real values.
# ═══════════════════════════════════════════════════════════════════


# ─── MongoDB Atlas connection ──────────────────────────────────────
# Get from: cloud.mongodb.com → Cluster → Connect → Drivers → Python
# (template — replace the angle-bracketed parts with real values; do NOT
# commit the filled-in version. The whole literal string below is a
# placeholder, not a real connection.)
MONGODB_URI=<paste-mongodb+srv-uri-from-atlas-here>


# ─── Database name ─────────────────────────────────────────────────
MONGODB_DB_NAME=motionlens


# ─── JWT secret for signing auth tokens ────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# Use a DIFFERENT secret in production.
JWT_SECRET=PASTE_A_LONG_RANDOM_STRING_HERE


# ─── JWT token expiry (seconds) ────────────────────────────────────
# 604800 = 7 days
JWT_EXPIRY_SECONDS=604800


# ─── CORS allowed origins ──────────────────────────────────────────
# Comma-separated. Use * to allow all (dev only).
# Production: https://your-app.vercel.app
MOTIONLENS_ALLOWED_ORIGINS=http://localhost:3000,*


# ─── Optional tuning ───────────────────────────────────────────────
MOTIONLENS_LIVE_POOL_SIZE=1
