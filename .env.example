# ═══════════════════════════════════════
# MotionLens API — Environment Variables
# AWS EC2 Deployment
# ═══════════════════════════════════════
# Copy this file to .env and fill in values
# NEVER commit .env to git

# ───────────────────────────────────────
# Database (Required)
# ───────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=motionlens

# ───────────────────────────────────────
# Auth (Required)
# ───────────────────────────────────────
# Generate a strong random key:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRY_SECONDS=604800

# ───────────────────────────────────────
# CORS (Required for production)
# ───────────────────────────────────────
# Comma separated list of allowed origins
# Add your Vercel URL + AWS domain
MOTIONLENS_ALLOWED_ORIGINS=https://gait-analysis123.vercel.app,http://localhost:3000

# ───────────────────────────────────────
# Server (Optional — has defaults)
# ───────────────────────────────────────
PORT=8000

# ───────────────────────────────────────
# Performance (Optional — has defaults)
# ───────────────────────────────────────
MOTIONLENS_LIVE_POOL_SIZE=1
MOTIONLENS_OVERLAY_SMOOTH_ALPHA=0.45
